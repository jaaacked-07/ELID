  var grid='';[0.25,0.5,0.75,1].forEach(function(g){grid+='<polygon points="'+perf.map(function(p,i){var q=pt(i,R*g);return q[0].toFixed(1)+','+q[1].toFixed(1);}).join(' ')+'" fill="none" stroke="rgba(201,160,176,.16)"/>';});
  var axes='',labels='',dots='';
  perf.forEach(function(p,i){var a=pt(i,R),l=pt(i,R+24),weak=p.v===minV;
    axes+='<line x1="'+cx+'" y1="'+cy+'" x2="'+a[0].toFixed(1)+'" y2="'+a[1].toFixed(1)+'" stroke="rgba(201,160,176,.16)"/>';
