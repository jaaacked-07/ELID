function autoPend(day){
  var items=[];
  if(day){ day.blocks.forEach(function(b){var f=effTask(b);
    if(b.tipo==='q'&&/Bateria/.test(b.act)) items.push({txt:'Fazer 20 questĂ”es de '+f.tema,tag:'questĂ”es'});
    else if(b.tipo==='q'&&/CorreĂ§ĂŁo/.test(b.act)) items.push({txt:'Corrigir erros das questĂ”es de '+f.tema,tag:'correĂ§ĂŁo'});
    else if(b.tipo==='rev'&&/Anki/.test(b.act)) items.push({txt:'Revisar flashcards acumulados (Anki)',tag:'revisĂŁo'});
    else if(b.tipo==='rev'&&/flashcards dos erros/i.test(b.act)) items.push({txt:'Criar flashcards dos erros de '+f.tema,tag:'flashcards'});
    else if(b.tipo==='teo') items.push({txt:'Ler teoria: '+f.tema,tag:'teoria'});
    else if(b.tipo==='sim') items.push({txt:f.act,tag:'simulado'});
    else if(b.tipo==='rev') items.push({txt:f.act,tag:'revisĂŁo'});
  }); }
  // revisĂ”es espaĂ§adas que vencem hoje
  var ti=iso(todayMid());
  revEvents().forEach(function(e){ if(e.iso===ti) items.push({txt:'Revisar (espaĂ§ada): '+e.tema,tag:e.kind}); });
  return items;
}
function renderPend(){
  var box=$('#pend-body');box.innerHTML='';
