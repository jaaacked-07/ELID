/* ---------- day element (minimizĂĄvel) ---------- */
function dayEl(day,anchor){
  var weekend=(day.dow===0||day.dow===6),collapsed=!!COLLAPSE[day.iso];
  var e=el('<div class="day'+(collapsed?' collapsed':'')+'" id="'+(anchor||('d-'+day.iso))+'">'+
    '<div class="day-head'+(weekend?' weekend':'')+'">'+
      '<span class="day-collapse">âŸ</span>'+
      '<div><div class="day-date">'+fmt(day.date)+' Â· '+DOW[day.dow]+'</div><div class="day-dow">Semana '+day.week.n+' Â· '+esc(day.week.area)+'</div></div>'+
      '<div class="day-tally" data-day="'+day.iso+'"></div></div></div>');
  day.blocks.forEach(function(b){e.appendChild(taskEl(b));});
  e.querySelector('.day-head').addEventListener('click',function(ev){
    if(ev.target.closest('.t-edit'))return;
    e.classList.toggle('collapsed');
    COLLAPSE[day.iso]=e.classList.contains('collapsed')?1:0; saveCollapse();
  });
  return e;
}
function tally(day){var tot=day.blocks.length,done=0;day.blocks.forEach(function(b){if(isDone(b.id))done++;});return {tot:tot,done:done};}
function weekDone(n){var ds=DAYS.filter(function(d){return d.week.n===n;}),tot=0,done=0;ds.forEach(function(d){var t=tally(d);tot+=t.tot;done+=t.done;});return tot>0&&done===tot;}
function refreshTallies(){
  document.querySelectorAll('.day-tally').forEach(function(node){var day=dayByIso(node.getAttribute('data-day'));if(!day)return;var t=tally(day);node.textContent=t.done+'/'+t.tot+' concluĂ­das';node.classList.toggle('done-all',t.tot>0&&t.done===t.tot);});
  document.querySelectorAll('.day-head').forEach(function(h){var node=h.querySelector('.day-tally');if(node){h.classList.toggle('done-all',node.classList.contains('done-all'));}});
  document.querySelectorAll('.cal-cell[data-iso]').forEach(function(c){var day=dayByIso(c.getAttribute('data-iso'));if(!day)return;var t=tally(day);c.classList.toggle('done',t.tot>0&&t.done===t.tot);});
  document.querySelectorAll('h3.grp[data-week]').forEach(function(h){var n=+h.getAttribute('data-week');h.classList.toggle('week-complete',weekDone(n));});
