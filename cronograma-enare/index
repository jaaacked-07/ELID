/* ============================================================
   POMODORO
   ============================================================ */
var Pomo={focus:25,brk:5,long:15,mode:'foco',remaining:25*60,running:false,cycles:0,timer:null};
function pomoFmt(s){var m=Math.floor(s/60),ss=s%60;return String(m).padStart(2,'0')+':'+String(ss).padStart(2,'0');}
function pomoRender(){
  $('#pomo-time').textContent=pomoFmt(Pomo.remaining);
  $('#pomo-mode').textContent=Pomo.mode==='foco'?'Foco':(Pomo.mode==='long'?'Pausa longa':'Pausa');
  $('#pomo-start').textContent=Pomo.running?'Pausar':'Iniciar';
  $('#pomo-cycles').textContent='Ciclos de foco concluĂ­dos: '+Pomo.cycles;
  document.title=(Pomo.running?pomoFmt(Pomo.remaining)+' Â· ':'')+'ELID Cronograma';
}
function pomoBeep(){try{var c=new(window.AudioContext||window.webkitAudioContext)();var o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.frequency.value=660;g.gain.value=.12;o.start();setTimeout(function(){o.frequency.value=880;},220);setTimeout(function(){o.stop();c.close();},520);}catch(e){}}
function pomoNext(){
  pomoBeep();
  if(Pomo.mode==='foco'){Pomo.cycles++;Pomo.mode=(Pomo.cycles%4===0)?'long':'pausa';Pomo.remaining=(Pomo.mode==='long'?Pomo.long:Pomo.brk)*60;toast('Foco concluĂ­do â hora da pausa');}
  else {Pomo.mode='foco';Pomo.remaining=Pomo.focus*60;toast('Pausa terminada â de volta ao foco');}
  Pomo.running=false;clearInterval(Pomo.timer);pomoRender();
}
function pomoTick(){if(Pomo.remaining<=0){pomoNext();return;}Pomo.remaining--;pomoRender();}
$('#pomo-start').addEventListener('click',function(){Pomo.running=!Pomo.running;if(Pomo.running){Pomo.timer=setInterval(pomoTick,1000);}else clearInterval(Pomo.timer);pomoRender();});
$('#pomo-reset').addEventListener('click',function(){Pomo.running=false;clearInterval(Pomo.timer);Pomo.remaining=(Pomo.mode==='foco'?Pomo.focus:Pomo.mode==='long'?Pomo.long:Pomo.brk)*60;pomoRender();});
$('#pomo-skip').addEventListener('click',function(){clearInterval(Pomo.timer);pomoNext();});
$('#cfg-focus').addEventListener('change',function(){Pomo.focus=Math.max(1,+this.value||25);if(Pomo.mode==='foco'&&!Pomo.running){Pomo.remaining=Pomo.focus*60;pomoRender();}});
$('#cfg-break').addEventListener('change',function(){Pomo.brk=Math.max(1,+this.value||5);if(Pomo.mode==='pausa'&&!Pomo.running){Pomo.remaining=Pomo.brk*60;pomoRender();}});
$('#cfg-long').addEventListener('change',function(){Pomo.long=Math.max(1,+this.value||15);if(Pomo.mode==='long'&&!Pomo.running){Pomo.remaining=Pomo.long*60;pomoRender();}});
$('#pomo-zen').addEventListener('click',function(){$('#pomo-stage').classList.add('zen');toast('Modo anti-distraĂ§ĂŁo â toque no relĂłgio para sair');});
$('.pomo-circle').addEventListener('click',function(){$('#pomo-stage').classList.remove('zen');});
$('#pomo-full').addEventListener('click',function(){var st=$('#pomo-stage');if(st.requestFullscreen)st.requestFullscreen();else if(st.webkitRequestFullscreen)st.webkitRequestFullscreen();});

