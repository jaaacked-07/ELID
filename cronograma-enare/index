    w.temas.forEach(function(tema,i){var base=addDays(ws,i);
      [[7,'7d','#7fd0a6'],[15,'15d','#d8a657'],[30,'30d','#cf8593']].forEach(function(r){var d=addDays(base,r[0]);if(d<=EXAM)ev.push({date:d,iso:iso(d),tema:tema,area:w.area.split('Â·')[0].trim(),kind:r[1],cor:r[2]});});
    });
  });
  ev.sort(function(a,b){return a.date-b.date;});return ev;
}
function renderRev(){
