    var d=pt(i,R*p.v/100);dots+='<circle cx="'+d[0].toFixed(1)+'" cy="'+d[1].toFixed(1)+'" r="'+(weak?5.5:3.5)+'" fill="'+(weak?'#e79a9a':'#cf8593')+'"/>';
  });
  var poly=perf.map(function(p,i){var d=pt(i,R*p.v/100);return d[0].toFixed(1)+','+d[1].toFixed(1);}).join(' ');
  $('#radar').innerHTML='<svg viewBox="0 0 350 270" style="width:100%">'+grid+axes+'<polygon points="'+poly+'" fill="rgba(183,110,121,.26)" stroke="#b76e79" stroke-width="2"/>'+dots+labels+'</svg>';
  var weakest=perf.slice().sort(function(a,b){return a.v-b.v;});
