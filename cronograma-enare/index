<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getAuth, onAuthStateChanged, signOut } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js';
import { getFirestore, doc, getDoc, setDoc } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

const firebaseConfig = {
  apiKey: "AIzaSyAKN3qsYIc3pel81vl8WEAH6Ob4oR-icAM",
  authDomain: "jackeline-study-platform.firebaseapp.com",
  projectId: "jackeline-study-platform",
  storageBucket: "jackeline-study-platform.firebasestorage.app",
  messagingSenderId: "574246127117",
  appId: "1:574246127117:web:29eedab81ea4251b23f744"
};

const PLATFORM_ID = 'cronograma'; // = nome da pasta (sagrado)
const SUBKEYS = ['state','edits','collapse','metrics','pend'];

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);

const $g = (id)=>document.getElementById(id);
function showLogin(){ $g('gate').style.display='flex'; $g('gate-loading').style.display='none'; $g('gate-login').style.display='block'; $g('app').style.display='none'; }
function showApp(){ $g('gate').style.display='none'; $g('app').style.display='block'; $g('topbar').style.display='flex'; }

// navegaĂ§ĂŁo da barra (â» volta Ă  biblioteca sem deslogar; Sair faz signOut real)
$g('tb-back').onclick = ()=>{ location.href='../../biblioteca-web/'; };
$g('tb-back2').onclick = ()=>{ location.href='../../biblioteca-web/'; };
$g('tb-exit').onclick = ()=>{ signOut(auth).finally(()=>{ location.href='../../landing-page/'; }); };

let saveTimer=null;
onAuthStateChanged(auth, async (user)=>{
  if(!user){ showLogin(); return; }
  const uid = user.uid;
  const prefix = 'elid_cron::'+uid+'::';
  const ref = doc(db,'users',uid,'platforms',PLATFORM_ID,'state','main');

  // hidrata o localStorage (namespace do usuĂĄrio) com o que estĂĄ na nuvem
  try{
    const snap = await getDoc(ref);
    if(snap.exists() && snap.data().data){
      const blob = JSON.parse(snap.data().data);
      SUBKEYS.forEach(k=>{ if(blob[k]!=null) localStorage.setItem(prefix+k, JSON.stringify(blob[k])); });
    }
  }catch(e){ console.warn('ELID load', e); }

  // salva na nuvem (debounce) sempre que o app gravar algo localmente
  window.__elidCloudSave = ()=>{
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async ()=>{
      try{
        const blob={};
        SUBKEYS.forEach(k=>{ const v=localStorage.getItem(prefix+k); if(v!=null) blob[k]=JSON.parse(v); });
        await setDoc(ref, { data: JSON.stringify(blob), updatedAt: Date.now() }, { merge:true });
      }catch(e){ console.warn('ELID save', e); }
    }, 1200);
  };

  $g('elid-user').textContent = user.email || 'Conta ELID';
  showApp();
  window.startApp(uid);
});
</script>
