<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>

<script>
(function(){
  "use strict";

  /* ===== Config (mesma de todo o ELID) ===== */
  var firebaseConfig = {
    apiKey: "AIzaSyAKN3qsYIc3pel81vl8WEAH6Ob4oR-icAM",
    authDomain: "jackeline-study-platform.firebaseapp.com",
    projectId: "jackeline-study-platform",
    storageBucket: "jackeline-study-platform.firebasestorage.app",
    messagingSenderId: "574246127117",
    appId: "1:574246127117:web:29eedab81ea4251b23f744"
  };

  var $ = function(s){ return document.querySelector(s); };
  var FB = { ready:false, auth:null, db:null, uid:null };

  /* =====================================================================
     REGISTRO DE PLATAFORMAS (adaptadores)
     Cada adaptador descreve ONDE e COMO ler/escrever os flashcards de uma
     plataforma. Só ative "rw" depois de confirmar o esquema lendo o arquivo
     real da plataforma — escrever no caminho/campo errado corrompe os dados.
     ===================================================================== */
  var PLATFORMS = [
    {
      key:"pediatria",
      label:"PedAtlas",
      href:"../plataformas/pediatria/",
      status:"rw",                                   // leitura + escrita confirmadas
      platformId:"PedAtlas by Jackeline Delfini",    // PLATFORM_ID literal real
      docPath:["data","main"],                       // .../platforms/{id}/data/main
      cardsField:"flashcards",                        // STATE.flashcards (array, criados pela usuária)
      srsField:"fcReviews"                            // STATE.fcReviews { cardId: {ease,interval,due,reps} }
    },
    { key:"neurologia",  label:"NeuroAtlas",          href:"../plataformas/neurologia/",  status:"soon" },
    { key:"ginecologia", label:"GinecoAtlas",         href:"../plataformas/ginecologia/", status:"soon" },
    { key:"obstetricia", label:"Atlas de Obstetrícia",href:"../plataformas/obstetricia/", status:"soon" },
    { key:"cirurgia",    label:"Cirurgia Geral",      href:"../plataformas/cirurgia/",    status:"soon" },
    { key:"pneumologia", label:"Pneumologia",         href:"../plataformas/pneumologia/", status:"soon" },
    { key:"preventiva",  label:"Med. Preventiva",     href:"../plataformas/preventiva/",  status:"soon" },
    { key:"semiologia",  label:"Semiologia",          href:"../plataformas/semiologia/",  status:"soon" }
  ];

  /* ===== Helpers de extração defensiva ===== */
  function cardId(c){ return c.id || c.cardId || c._id || null; }
  function cardFront(c){
    return c.front || c.frente || c.q || c.pergunta || c.statement || c.text || c.title || "(frente)";
  }
  function cardBack(c){
    if(typeof c.answer === "boolean" || c.type === "fv") return c.answer ? "Verdadeiro" : "Falso";
    return c.back || c.verso || c.a || c.resposta || c.answerText || c.explicacao || "";
  }
  function isDue(rev){
    if(!rev || rev.due == null) return true;     // sem agendamento = novo = revisar hoje
    return Number(rev.due) <= Date.now();
  }

  /* ===== SM-2 (grava exatamente os campos que o PedAtlas lê) =====
     grade: 0 Errei · 1 Difícil · 2 Bom · 3 Fácil */
  function schedule(prev, grade){
    var ease = (prev && prev.ease) || 2.5;
    var interval = (prev && prev.interval) || 0;
    var reps = (prev && prev.reps) || 0;
    var DAY = 86400000;
    if(grade === 0){
      return { ease: Math.max(1.3, ease - 0.2), interval: 0, reps: 0, due: Date.now() + 10*60*1000 };
    }
    reps += 1;
    if(grade === 1){
      ease = Math.max(1.3, ease - 0.15);
      interval = interval <= 0 ? 1 : Math.max(1, Math.round(interval * 1.2));
    } else if(grade === 2){
      interval = interval <= 0 ? 1 : (reps === 1 ? 1 : Math.round(interval * ease));
    } else {
      ease = ease + 0.05;
      interval = interval <= 0 ? 2 : Math.round(interval * ease * 1.3);
    }
    return { ease: ease, interval: interval, reps: reps, due: Date.now() + interval * DAY };
  }

  /* ===== Acesso ao documento de uma plataforma ===== */
  function platformDocRef(p){
    return FB.db.collection("users").doc(FB.uid)
      .collection("platforms").doc(p.platformId)
      .collection(p.docPath[0]).doc(p.docPath[1]);
  }

  /* ===== Estado da Central ===== */
  var SESSION = {
    queue: [],          // [{p, card, rev, srsMap (ref ao objeto carregado)}]
    index: 0,
    doneToday: 0,
    activeCount: 0,
    docCache: {}        // platformId -> {ref, state}
  };

  function toast(msg){
    var t = document.createElement("div"); t.className = "toast"; t.textContent = msg;
    $("#toasts").appendChild(t);
    setTimeout(function(){ if(t.parentNode) t.parentNode.removeChild(t); }, 2600);
  }

  /* ===== Carrega flashcards devidos de todas as plataformas "rw" ===== */
  function loadAll(){
    var rwPlats = PLATFORMS.filter(function(p){ return p.status === "rw"; });
    SESSION.activeCount = rwPlats.length;
    var pending = rwPlats.length;
    var internalPending = 0;

    if(pending === 0){ render(0, internalPending); return; }

    rwPlats.forEach(function(p){
      platformDocRef(p).get().then(function(doc){
        if(doc.exists){
          var state = doc.data() || {};
          SESSION.docCache[p.platformId] = { ref: platformDocRef(p), state: state, p: p };
          var cards = Array.isArray(state[p.cardsField]) ? state[p.cardsField] : [];
          var srs = state[p.srsField] || {};
          var knownIds = {};
          cards.forEach(function(c){
            var id = cardId(c); if(!id) return;
            knownIds[id] = true;
            if(isDue(srs[id])){
              SESSION.queue.push({ p:p, id:id, card:c, rev: srs[id] || null });
            }
          });
          // cards internos (prontos): têm agendamento mas o texto não está no Firestore
          Object.keys(srs).forEach(function(id){
            if(!knownIds[id] && isDue(srs[id])) internalPending++;
          });
        }
      }).catch(function(e){
        console.warn("Falha lendo", p.label, e);
      }).then(function(){
        pending--;
        if(pending === 0){ render(rwPlats.length, internalPending); }
      });
    });
  }

  /* ===== Render ===== */
  function render(activeCount, internalPending){
    $("#s-flash").textContent = SESSION.queue.length;
    $("#s-done").textContent = SESSION.doneToday;
    $("#s-plat").textContent = activeCount;
    renderPlatforms();
    renderInternal(internalPending);
    renderQuest();
    renderStage();
  }

  function renderStage(){
    var area = $("#flash-area");
    if(SESSION.queue.length === 0){
      area.innerHTML =
        '<div class="panel"><div class="big">Nenhuma revisão pendente</div>' +
        '<p>Você está em dia com os flashcards de hoje. Crie novos cards nas plataformas ou volte amanhã.</p>' +
        '<a class="cta" href="../biblioteca-web/">Voltar à Biblioteca</a></div>';
      return;
    }
    if(SESSION.index >= SESSION.queue.length){
      area.innerHTML =
        '<div class="panel"><div class="big">Revisão concluída &#10022;</div>' +
        '<p>Você revisou ' + SESSION.doneToday + ' card(s) hoje. Reagendados pela revisão espaçada — vão reaparecer no dia certo, aqui e na plataforma.</p></div>';
      return;
    }
    var item = SESSION.queue[SESSION.index];
    area.innerHTML =
      '<div class="review-stage">' +
        '<div class="flash" id="flash">' +
          '<div class="flash-inner">' +
            '<div class="flash-face">' +
              '<span class="face-tag">Frente</span><span class="face-src">' + esc(item.p.label) + '</span>' +
              '<div class="face-text">' + safe(cardFront(item.card)) + '</div>' +
              '<div class="face-hint">toque para ver a resposta</div>' +
            '</div>' +
            '<div class="flash-face flash-back">' +
              '<span class="face-tag">Verso</span><span class="face-src">' + esc(item.p.label) + '</span>' +
              '<div class="face-text">' + (cardBack(item.card) ? safe(cardBack(item.card)) : '<span style="opacity:.6">(sem verso registrado)</span>') + '</div>' +
            '</div>' +
          '</div>' +
        '</div>' +
        '<div class="rate-row" id="rates" hidden>' +
          '<button class="rate r0" data-g="0"><b>Errei</b><small>10 min</small></button>' +
          '<button class="rate r1" data-g="1"><b>Difícil</b><small>+ curto</small></button>' +
          '<button class="rate r2" data-g="2"><b>Bom</b><small>padrão</small></button>' +
          '<button class="rate r3" data-g="3"><b>Fácil</b><small>+ longo</small></button>' +
        '</div>' +
        '<div class="stage-nav"><span>Card ' + (SESSION.index + 1) + ' de ' + SESSION.queue.length + '</span>' +
        '<span>' + SESSION.doneToday + ' revisados hoje</span></div>' +
      '</div>';

    var flash = $("#flash");
    flash.addEventListener("click", function(){
      flash.classList.add("flipped");
      $("#rates").hidden = false;
    });
    Array.prototype.forEach.call(document.querySelectorAll("#rates .rate"), function(btn){
      btn.addEventListener("click", function(){ rate(parseInt(btn.getAttribute("data-g"), 10)); });
    });
  }

  function rate(grade){
    var item = SESSION.queue[SESSION.index];
    var newRev = schedule(item.rev, grade);
    var cache = SESSION.docCache[item.p.platformId];
    if(!cache){ next(); return; }

    // atualiza o mapa de SRS em memória e grava de volta no MESMO documento (merge)
    var srs = cache.state[item.p.srsField] || {};
    srs[item.id] = newRev;
    cache.state[item.p.srsField] = srs;

    var update = {};
    update[item.p.srsField] = srs;          // grava o mapa inteiro de fcReviews (merge não toca nos demais campos)
    cache.ref.set(update, { merge: true }).catch(function(e){
      console.warn("Falha ao salvar revisão", e);
      toast("Não consegui salvar — verifique a conexão.");
    });

    SESSION.doneToday++;
    next();
  }

  function next(){
    SESSION.index++;
    $("#s-done").textContent = SESSION.doneToday;
    renderStage();
  }

  function renderInternal(n){
    var area = $("#internal-area");
    if(!n){ area.innerHTML = ""; return; }
    area.innerHTML =
      '<div class="pending-row">' +
        '<span>+ ' + n + ' flashcard(s) prontos do PedAtlas vencem hoje (o texto deles fica na plataforma).</span>' +
        '<a href="../plataformas/pediatria/">Revisar no PedAtlas →</a>' +
      '</div>';
  }

  function renderQuest(){
    $("#quest-area").innerHTML =
      '<div class="panel"><div class="big">Questões por plataforma</div>' +
      '<p>As questões do dia são geradas dentro de cada Atlas. Resolva por aqui o atalho e o progresso fica salvo na plataforma.</p>' +
      '<a class="cta" href="../plataformas/pediatria/">Questões do dia · PedAtlas</a></div>';
  }

  function renderPlatforms(){
    var html = "";
    PLATFORMS.forEach(function(p){
      var on = p.status === "rw";
      html +=
        '<a class="plat" href="' + p.href + '">' +
          '<div class="name">' + esc(p.label) + '</div>' +
          '<div class="st ' + (on ? "on" : "off") + '">' + (on ? "● Conectada" : "○ A conectar") + '</div>' +
        '</a>';
    });
    $("#plat-grid").innerHTML = html;
  }

  /* ===== util ===== */
  function esc(s){ return String(s == null ? "" : s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
  // permite HTML simples já existente nos cards (negrito etc.), mas neutraliza <script>
  function safe(s){ return String(s == null ? "" : s).replace(/<\s*script/gi, "&lt;script"); }

  /* ===== Auth + boot ===== */
  function boot(){
    try{
      if(typeof firebase === "undefined"){ throw new Error("SDK indisponível"); }
      if(!firebase.apps || !firebase.apps.length){ firebase.initializeApp(firebaseConfig); }
      FB.auth = firebase.auth();
      FB.db = firebase.firestore();
      FB.ready = true;

      FB.auth.onAuthStateChanged(function(user){
        $("#loader").style.display = "none";
        if(!user){
          $("#gate").classList.add("show");
          $("#app").hidden = true;
          return;
        }
        FB.uid = user.uid;
        $("#gate").classList.remove("show");
        $("#app").hidden = false;
        showToday();
        loadAll();
      });
    }catch(e){
      $("#loader").style.display = "none";
      $("#gate").classList.add("show");
      console.warn("Firebase indisponível:", e);
    }
  }

  function showToday(){
    try{
      var d = new Date();
      $("#today").textContent = d.toLocaleDateString("pt-BR", { weekday:"long", day:"numeric", month:"long" });
    }catch(e){ $("#today").textContent = ""; }
  }

  /* ===== Topbar handlers ===== */
  // ⏻/seta: volta à biblioteca SEM deslogar
  document.getElementById("btn-back").addEventListener("click", function(){
    window.location.href = "../biblioteca-web/";
  });
  // Sair do ELID: signOut real -> landing
  document.getElementById("btn-logout").addEventListener("click", function(){
    if(!confirm("Sair do ELID?")) return;
    if(FB.auth){ FB.auth.signOut().then(function(){ window.location.href = "../landing-page/"; })
      .catch(function(){ window.location.href = "../landing-page/"; }); }
    else { window.location.href = "../landing-page/"; }
  });
  // Tema
  document.getElementById("btn-theme").addEventListener("click", function(){
    document.body.classList.toggle("light-mode");
    var icon = document.getElementById("icon-theme");
    icon.innerHTML = document.body.classList.contains("light-mode")
      ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
      : '<path d="M10 2a1 1 0 011 1v2a1 1 0 11-2 0V3a1 1 0 011-1zM4.22 4.22a1 1 0 011.415 0l1.414 1.415a1 1 0 01-1.414 1.414L4.22 5.636a1 1 0 010-1.414zM2 10a1 1 0 011 1v2a1 1 0 11-2 0v-2a1 1 0 011-1zm14 0a1 1 0 011 1v2a1 1 0 11-2 0v-2a1 1 0 011-1zM4.22 15.78a1 1 0 010-1.415l1.414-1.414a1 1 0 111.414 1.414l-1.414 1.415a1 1 0 01-1.414 0zM10 18a1 1 0 01-1-1v-2a1 1 0 112 0v2a1 1 0 01-1 1zm6-6a4 4 0 11-8 0 4 4 0 018 0z"/>';
  });

  /* ===== Canvas (mesmo clima da Biblioteca) ===== */
  (function(){
    var canvas = document.getElementById("bg"), ctx = canvas.getContext("2d");
    var particles = [], w, h;
    function resize(){ w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
    resize(); window.addEventListener("resize", resize);
    for(var i=0;i<60;i++){
      particles.push({ x:Math.random()*w, y:Math.random()*h, vx:(Math.random()-0.5)*0.15, vy:(Math.random()-0.5)*0.1, r:Math.random()*1.2+0.4, alpha:Math.random()*0.3+0.08 });
    }
    function draw(){
      ctx.clearRect(0,0,w,h);
      var t = Date.now()*0.0003;
      var grd = ctx.createRadialGradient(w*0.5+Math.sin(t)*100, h*0.3, 50, w*0.5, h*0.5, h*0.8);
      grd.addColorStop(0,"rgba(183,110,121,0.05)"); grd.addColorStop(0.5,"rgba(45,27,46,0)"); grd.addColorStop(1,"rgba(45,27,46,0)");
      ctx.fillStyle=grd; ctx.fillRect(0,0,w,h);
      particles.forEach(function(p){
        p.x+=p.vx; p.y+=p.vy;
        if(p.x<0)p.x=w; if(p.x>w)p.x=0; if(p.y<0)p.y=h; if(p.y>h)p.y=0;
        ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx.fillStyle="rgba(247,231,206,"+p.alpha+")"; ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();

  boot();
})();
</script>
