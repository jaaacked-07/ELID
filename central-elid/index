<!doctype html>
<html lang="pt-BR" class="h-full">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
<title>Central ELID</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Raleway:wght@200;300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root{
    --rose-gold:#b76e79; --champagne:#f7e7ce; --deep-plum:#2d1b2e;
    --soft-mauve:#c9a0b0; --ivory:#faf6f0; --off-white:#f5f0e8; --light-beige:#e8dcc8;
  }
  *{box-sizing:border-box;}
  html,body{height:100%;margin:0;}
  body{font-family:'Raleway',sans-serif;background:var(--deep-plum);color:var(--ivory);overflow-x:hidden;}
  body.light-mode{background:linear-gradient(135deg,var(--off-white) 0%,var(--light-beige) 100%);color:var(--deep-plum);}
  a{text-decoration:none;color:inherit;}
  .font-cormorant{font-family:'Cormorant Garamond',serif;}
  .font-script{font-family:'Great Vibes',cursive;}
  .hl{color:var(--rose-gold);font-weight:500;}

  canvas#bg{position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;}
  body.light-mode #bg{opacity:.3;}

  /* Topbar */
  .topbar{position:fixed;top:0;left:0;right:0;height:64px;display:flex;align-items:center;justify-content:space-between;
    padding:0 28px;z-index:50;background:rgba(45,27,46,.42);backdrop-filter:blur(16px);border-bottom:1px solid rgba(183,110,121,.12);}
  body.light-mode .topbar{background:rgba(255,255,255,.6);border-bottom-color:rgba(183,110,121,.18);}
  .topbar::after{content:"";position:absolute;left:0;right:0;bottom:0;height:3px;background:var(--rose-gold);opacity:.8;}
  .tb-title{font-family:'Cormorant Garamond',serif;font-size:23px;font-weight:300;letter-spacing:.12em;}
  .tb-controls{display:flex;gap:12px;align-items:center;}
  .btn-icon{width:40px;height:40px;border-radius:50%;background:rgba(183,110,121,.12);border:1px solid rgba(183,110,121,.22);
    cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--rose-gold);transition:all .3s ease;}
  .btn-icon:hover{background:rgba(183,110,121,.25);transform:scale(1.08);box-shadow:0 0 15px rgba(183,110,121,.2);}
  body.light-mode .btn-icon{background:rgba(183,110,121,.08);}

  .wrap{position:relative;z-index:10;max-width:1080px;margin:0 auto;padding:96px 28px 80px;}

  /* Hero */
  .hero{text-align:center;margin-bottom:52px;}
  .convergence{width:64px;height:64px;margin:0 auto 18px;display:block;color:var(--rose-gold);opacity:.9;}
  .hero h1{font-family:'Cormorant Garamond',serif;font-weight:300;letter-spacing:.16em;font-size:clamp(34px,6vw,48px);margin:0 0 6px;}
  .hero .eyebrow{font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:rgba(201,160,176,.75);}
  body.light-mode .hero .eyebrow{color:rgba(120,80,100,.75);}
  .hero .tribute{font-family:'Great Vibes',cursive;font-size:1.5rem;color:var(--rose-gold);margin-top:14px;text-shadow:0 0 22px rgba(183,110,121,.25);}
  body.light-mode .hero .tribute{color:#9a5562;text-shadow:none;}
  .hero .today{font-size:13px;letter-spacing:.12em;color:rgba(201,160,176,.7);margin-top:14px;text-transform:capitalize;}
  body.light-mode .hero .today{color:rgba(120,80,100,.7);}

  /* Resumo do dia */
  .summary{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:48px;}
  @media(max-width:640px){.summary{grid-template-columns:1fr;}}
  .sum-card{background:rgba(183,110,121,.08);border:1px solid rgba(183,110,121,.2);border-radius:16px;padding:22px;text-align:center;}
  body.light-mode .sum-card{background:rgba(183,110,121,.06);border-color:rgba(183,110,121,.25);}
  .sum-num{font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:var(--rose-gold);line-height:1;}
  .sum-lab{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(201,160,176,.7);margin-top:8px;}
  body.light-mode .sum-lab{color:rgba(120,80,100,.7);}

  /* Section heads */
  .cat-head{display:flex;align-items:center;justify-content:center;gap:12px;margin:0 0 26px;}
  .cat-mark{color:var(--rose-gold);font-size:16px;opacity:.85;}
  .cat-title{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:24px;letter-spacing:.3em;text-transform:uppercase;margin:0;padding-left:.3em;}

  /* Flashcard de revisão */
  .review-stage{max-width:560px;margin:0 auto 40px;}
  .flash{position:relative;border-radius:20px;min-height:230px;cursor:pointer;perspective:1200px;}
  .flash-inner{position:relative;width:100%;min-height:230px;transition:transform .55s cubic-bezier(.34,1.1,.5,1);transform-style:preserve-3d;}
  .flash.flipped .flash-inner{transform:rotateY(180deg);}
  .flash-face{position:absolute;inset:0;backface-visibility:hidden;border-radius:20px;padding:30px;display:flex;flex-direction:column;
    justify-content:center;align-items:center;text-align:center;
    background:linear-gradient(135deg,rgba(183,110,121,.14) 0%,rgba(247,231,206,.06) 100%);
    border:1px solid rgba(247,231,206,.28);}
  body.light-mode .flash-face{background:linear-gradient(135deg,rgba(183,110,121,.1) 0%,rgba(247,231,206,.16) 100%);border-color:rgba(183,110,121,.28);}
  .flash-back{transform:rotateY(180deg);}
  .face-tag{position:absolute;top:14px;left:18px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,160,176,.65);}
  .face-src{position:absolute;top:14px;right:18px;font-size:10px;letter-spacing:.12em;color:var(--rose-gold);}
  .face-text{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:clamp(20px,3.4vw,26px);line-height:1.4;}
  .face-hint{position:absolute;bottom:14px;left:0;right:0;font-size:11px;letter-spacing:.1em;color:rgba(201,160,176,.55);}
  body.light-mode .face-hint{color:rgba(120,80,100,.55);}

  .rate-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:18px;}
  .rate{padding:13px 8px;border-radius:13px;border:1px solid rgba(183,110,121,.25);background:rgba(183,110,121,.08);
    cursor:pointer;text-align:center;transition:all .25s ease;color:inherit;font-family:inherit;}
  .rate:hover{transform:translateY(-2px);background:rgba(183,110,121,.18);}
  .rate b{display:block;font-size:14px;font-weight:500;}
  .rate small{display:block;font-size:10px;letter-spacing:.06em;color:rgba(201,160,176,.7);margin-top:3px;}
  body.light-mode .rate small{color:rgba(120,80,100,.7);}
  .rate.r0{border-color:rgba(198,90,100,.4);} .rate.r0:hover{background:rgba(198,90,100,.18);}
  .rate.r3{border-color:rgba(150,180,140,.4);} .rate.r3:hover{background:rgba(150,180,140,.18);}
  .rate:disabled{opacity:.4;cursor:default;transform:none;}

  .stage-nav{display:flex;align-items:center;justify-content:space-between;margin-top:16px;font-size:12px;letter-spacing:.1em;color:rgba(201,160,176,.7);}
  body.light-mode .stage-nav{color:rgba(120,80,100,.7);}

  /* Empty / states */
  .panel{background:rgba(45,27,46,.32);backdrop-filter:blur(18px);border:1px solid rgba(183,110,121,.15);border-radius:18px;padding:30px;text-align:center;}
  body.light-mode .panel{background:rgba(255,255,255,.55);border-color:rgba(183,110,121,.2);}
  .panel .big{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;margin-bottom:8px;}
  .panel p{color:rgba(201,160,176,.78);font-size:14px;line-height:1.6;margin:6px 0;}
  body.light-mode .panel p{color:rgba(120,80,100,.78);}

  .cta{display:inline-block;margin-top:14px;padding:11px 22px;border-radius:999px;border:1px solid rgba(183,110,121,.4);
    color:var(--rose-gold);font-size:13px;letter-spacing:.08em;transition:all .25s ease;}
  .cta:hover{background:rgba(183,110,121,.16);box-shadow:0 0 18px rgba(183,110,121,.18);}

  .pending-row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;border-radius:13px;
    background:rgba(183,110,121,.07);border:1px solid rgba(183,110,121,.16);margin-bottom:24px;font-size:13px;}
  body.light-mode .pending-row{background:rgba(183,110,121,.06);}
  .pending-row a{color:var(--rose-gold);letter-spacing:.06em;white-space:nowrap;}

  /* Plataformas conectadas */
  .plat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;margin-top:8px;}
  .plat{padding:16px 18px;border-radius:14px;border:1px solid rgba(183,110,121,.18);background:rgba(183,110,121,.06);}
  .plat .name{font-size:14px;font-weight:500;letter-spacing:.04em;}
  .plat .st{font-size:11px;letter-spacing:.1em;text-transform:uppercase;margin-top:6px;}
  .plat .st.on{color:#9fc78f;} .plat .st.off{color:rgba(201,160,176,.6);}
  body.light-mode .plat .st.off{color:rgba(120,80,100,.6);}

  /* Acesso pelo ELID */
  .gate{position:fixed;inset:0;z-index:80;display:none;align-items:center;justify-content:center;padding:24px;
    background:rgba(45,27,46,.92);backdrop-filter:blur(10px);}
  .gate.show{display:flex;}
  .gate .card{max-width:420px;text-align:center;}
  .gate .mark{font-family:'Great Vibes',cursive;font-size:3rem;color:var(--rose-gold);}
  #loader{position:fixed;inset:0;z-index:90;display:flex;align-items:center;justify-content:center;background:var(--deep-plum);}
  .spin{width:42px;height:42px;border:3px solid rgba(183,110,121,.25);border-top-color:var(--rose-gold);border-radius:50%;animation:spin 1s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  .toast-wrap{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);z-index:100;display:flex;flex-direction:column;gap:8px;}
  .toast{padding:11px 20px;border-radius:999px;font-size:13px;letter-spacing:.04em;color:#fff;
    background:linear-gradient(100deg,var(--rose-gold),var(--soft-mauve));box-shadow:0 8px 24px rgba(0,0,0,.25);
    animation:tin .35s both;}
  @keyframes tin{from{opacity:0;transform:translateY(12px);}}

  .footer{position:relative;z-index:10;text-align:center;padding:34px 24px;border-top:1px solid rgba(183,110,121,.1);
    color:rgba(201,160,176,.5);font-size:12px;letter-spacing:.1em;}
  body.light-mode .footer{border-top-color:rgba(183,110,121,.2);color:rgba(120,80,100,.6);}
  [hidden]{display:none!important;}
</style>
</head>
